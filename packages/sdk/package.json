{
  "name": "@9jacheckr/sdk",
  "version": "0.1.0",
  "description": "Client for the 9ja Checkr NAFDAC verify API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "npm run check-types"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "nafdac",
    "9ja-checkr",
    "nigeria"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  }
}
